<header class="site-header" role="banner">
  <div class="site-header__container" style="display:flex;align-items:center;gap:24px;padding:14px 20px;">
    <a href="index.html" class="site-header__logo" aria-label="GeniusTax Home" style="display:inline-block;flex:0 0 auto;">
      <img src="images/brand.png" alt="GeniusTax" width="126" height="126" style="display:block;width:126px;height:126px;object-fit:contain;" />
    </a>

    <button class="site-header__burger" aria-label="Open menu" aria-expanded="false" aria-controls="primary-nav">
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" class="site-header__nav" role="navigation" style="flex:1 1 auto;">
      <ul class="site-header__menu" style="list-style:none;display:flex;justify-content:center;gap:64px;margin:0;padding:0;">
        <li><a data-i18n="nav.home" href="index.html">Home</a></li>
        <li><a data-i18n="nav.services" href="Services.html">Services</a></li>
        <li><a data-i18n="nav.about" href="About-us.html">About</a></li>
        <li><a data-i18n="nav.contact" href="Contact.html">Contacts</a></li>
      </ul>
    </nav>

    <div class="site-header__right" style="display:flex;align-items:center;gap:12px;flex:0 0 auto;">
      <div class="site-header__lang-wrap" style="position:relative;">
        <button class="site-header__lang" aria-label="Language selector" aria-expanded="false">
          <svg viewBox="0 0 16 16" width="16" height="16" class="site-header__caret"><polygon points="8,12 2,4 14,4"></polygon></svg>
          <span class="site-header__flag" aria-hidden="true"></span>
        </button>
        <div class="site-header__lang-menu" role="menu" style="display:none;position:absolute;right:0;top:calc(100% + 8px);background:#fff;border:1px solid #e5e7eb;box-shadow:0 8px 24px rgba(0,0,0,.12);border-radius:6px;padding:8px;z-index:1000;min-width:140px">
          <button class="site-header__lang-item" data-lang="en" style="display:flex;align-items:center;gap:8px;background:none;border:0;width:100%;text-align:left;padding:8px 10px;cursor:pointer">English</button>
          <button class="site-header__lang-item" data-lang="ru" style="display:flex;align-items:center;gap:8px;background:none;border:0;width:100%;text-align:left;padding:8px 10px;cursor:pointer">Русский</button>
          <button class="site-header__lang-item" data-lang="ro" style="display:flex;align-items:center;gap:8px;background:none;border:0;width:100%;text-align:left;padding:8px 10px;cursor:pointer">Română</button>
        </div>
      </div>
      <a href="https://cal.com/geniustax/geniustax?overlayCalendar=true" class="site-header__cta" data-i18n="cta.consult" style="background:#f2a13a;color:#fff;padding:12px 22px;border-radius:0;font-weight:700;text-decoration:none;white-space:nowrap;">Consultation</a>
    </div>
  </div>
  <div class="site-header__overlay" aria-hidden="true"></div>
</header>
<script>
  (function(){
    var header = document.currentScript && document.currentScript.previousElementSibling;
    var b = header && header.querySelector('.site-header__burger');
    var nav = header && header.querySelector('#primary-nav');
    var ov = header && header.querySelector('.site-header__overlay');
    if (b && nav && header) {
      b.addEventListener('click', function(){
        var open = header.classList.toggle('is-open');
        b.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    }
    if (ov && header){ ov.addEventListener('click', function(){ header.classList.remove('is-open'); b && b.setAttribute('aria-expanded','false'); }); }
    // set active flag from localStorage lang
    var lang = (localStorage && localStorage.getItem('lang')) || 'en';
    var flag = document.currentScript.previousElementSibling.querySelector('.site-header__flag');
    if (flag) {
      var svg = '';
      if (lang === 'ru') svg = '<svg viewBox="0 0 112 112" width="24" height="24"><rect y="16" fill="#F4F4F4" width="112" height="26.7"/><rect y="42.7" fill="#323E95" width="112" height="26.7"/><rect y="69.3" fill="#D8001E" width="112" height="26.7"/></svg>';
      else if (lang === 'ro') svg = '<svg viewBox="0 0 112 112" width="24" height="24"><rect y="16" fill="#F3D54D" width="112" height="80"/><rect y="16" fill="#293D86" width="37.3" height="80"/><rect x="74.7" y="16" fill="#D23333" width="37.3" height="80"/></svg>';
      else svg = '<svg viewBox="0 0 112 112" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="16" width="112" height="80" fill="#012169"/><path d="M0 16 L112 96 M112 16 L0 96" stroke="#FFFFFF" stroke-width="18"/><path d="M0 16 L112 96 M112 16 L0 96" stroke="#C8102E" stroke-width="10"/><rect x="0" y="52" width="112" height="8" fill="#FFFFFF"/><rect x="52" y="16" width="8" height="80" fill="#FFFFFF"/><rect x="0" y="54" width="112" height="4" fill="#C8102E"/><rect x="54" y="16" width="4" height="80" fill="#C8102E"/></svg>';
      flag.innerHTML = svg;
    }

    // mark active menu item by current pathname
    try {
      var current = new URL(location.href);
      var path = current.pathname.toLowerCase();
      if (path === '/' || path === '') path = '/index.html';
      var root = header;
      var links = root.querySelectorAll('.site-header__menu a');
      links.forEach(function(a){
        var link = new URL(a.getAttribute('href'), location.href).pathname.toLowerCase();
        // consider both exact and partial match
        var isActive = (path === link) || (path.endsWith('/index.html') && (link.endsWith('/index.html') || link === './')) || (path.indexOf('about-us')>-1 && link.indexOf('about-us')>-1) || (path.indexOf('services')>-1 && link.indexOf('services')>-1) || (path.indexOf('contact')>-1 && link.indexOf('contact')>-1);
        if (isActive) a.classList.add('is-active');
      });
    } catch(e){}

    // language dropdown toggle and change
    try{
      var wrap = header.querySelector('.site-header__lang-wrap');
      var btn = header.querySelector('.site-header__lang');
      var menu = header.querySelector('.site-header__lang-menu');
      if (btn && wrap && menu){
        btn.addEventListener('click', function(e){
          e.stopPropagation(); var open = menu.style.display === 'block';
          menu.style.display = open ? 'none' : 'block';
          btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        });
        document.addEventListener('click', function(){ menu.style.display='none'; btn.setAttribute('aria-expanded','false'); });
        menu.addEventListener('click', function(e){
          var t = e.target.closest('[data-lang]');
          if (!t) return;
          var l = t.getAttribute('data-lang');
          try{ localStorage.setItem('lang', l); }catch(_){ }
          location.reload();
        });
      }
    }catch(e){}
  })();
  </script>
