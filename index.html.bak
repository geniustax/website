    <section class="hero">
      <div class="hero-container">
        <div class="hero-content">
          <div class="hero-eyebrow">Бухгалтерия и налоги в Нидерландах</div>
          
          <h1 class="hero-title">GeniusTax — бухгалтерия<br>на вашем языке</h1>
          
          <p class="hero-subtitle">Помогаем русскоязычным предпринимателям, zzp и фрилансерам в Нидерландах вести учёт, сдавать декларации и общаться с Belastingdienst без стресса и сложных терминов.</p>
          
          <div class="hero-buttons">
            <a href="https://cal.com/geniustax/geniustax?overlayCalendar=true" class="hero-btn-primary">Связаться с нами</a>
            <a href="Services.html#standard" class="hero-btn-secondary">Наши пакеты</a>
          </div>
          
          <div class="hero-stats">
            <div class="stat-item">
              <div class="stat-value">5+ лет</div>
              <div class="stat-label">сопровождения бизнеса в Нидерландах</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">150+</div>
              <div class="stat-label">клиентов: zzp, freelancers, BV</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">98%</div>
              <div class="stat-label">деклараций вовремя за последние годы</div>
            </div>
          </div>
        </div>
        
        <div class="hero-visual">
          <div class="hero-bg-gradient"></div>
          <img src="images/photos/nadejda-office-standing-white.png" alt="Надежда, основатель GeniusTax" class="hero-image">
          
          <div class="service-chip chip-1">Ведение учёта</div>
          <div class="service-chip chip-2">Налоговые консультации</div>
          <div class="service-chip chip-3">Сопровождение проверок</div>
        </div>
      </div>
    </section>

    <!-- Hero Section Styles -->
    <style>
      .hero {
        background: #fff;
        padding: 80px 20px;
        min-height: 90vh;
        display: flex;
        align-items: center;
      }

      .hero-container {
        max-width: 1280px;
        margin: 0 auto;
        width: 100%;
        display: grid;
        grid-template-columns: 55% 45%;
        gap: 60px;
        align-items: center;
      }

      .hero-content {
        display: flex;
        flex-direction: column;
        gap: 24px;
      }

      .hero-eyebrow {
        font-size: 14px;
        color: #0097a7;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .hero-title {
        font-size: 3.5rem;
        font-weight: 700;
        line-height: 1.1;
        color: #111827;
        margin: 0;
      }

      .hero-subtitle {
        font-size: 1.125rem;
        color: #6B7280;
        line-height: 1.6;
        margin: 0;
      }

      .hero-buttons {
        display: flex;
        gap: 16px;
        margin-top: 16px;
      }

      .hero-btn-primary {
        background: #0097a7;
        color: white;
        padding: 16px 32px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 16px;
        text-decoration: none;
        box-shadow: 0 4px 14px rgba(0, 151, 167, 0.25);
        transition: all 0.3s ease;
        display: inline-block;
      }

      .hero-btn-primary:hover {
        background: #00838f;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0, 151, 167, 0.35);
        color: white;
      }

      .hero-btn-secondary {
        background: white;
        color: #111827;
        padding: 16px 32px;
        border: 2px solid #E5E7EB;
        border-radius: 12px;
        font-weight: 600;
        font-size: 16px;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
      }

      .hero-btn-secondary:hover {
        border-color: #0097a7;
        color: #0097a7;
        transform: translateY(-2px);
      }

      .hero-stats {
        display: flex;
        gap: 40px;
        margin-top: 40px;
      }

      .stat-item {
        display: flex;
        flex-direction: column;
      }

      .stat-value {
        font-size: 2.5rem;
        font-weight: 700;
        color: #111827;
        line-height: 1;
      }

      .stat-label {
        font-size: 14px;
        color: #6B7280;
        margin-top: 8px;
        line-height: 1.4;
        max-width: 120px;
      }

      .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 600px;
      }

      .hero-bg-gradient {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 480px;
        height: 480px;
        background: radial-gradient(circle, #E5F6FF 0%, #D9F0FF 100%);
        border-radius: 50%;
        z-index: 1;
      }

      .hero-image {
        position: relative;
        z-index: 2;
        width: 420px;
        height: 520px;
        object-fit: cover;
        border-radius: 20px;
        box-shadow: 0 20px 60px rgba(0, 151, 167, 0.15);
      }

      .service-chip {
        position: absolute;
        background: white;
        padding: 12px 20px;
        border-radius: 999px;
        box-shadow: 0 8px 32px rgba(0, 151, 167, 0.12);
        font-size: 14px;
        font-weight: 500;
        color: #374151;
        white-space: nowrap;
        z-index: 3;
        border: 1px solid rgba(0, 151, 167, 0.08);
      }

      .chip-1 {
        top: 80px;
        right: 20px;
      }

      .chip-2 {
        top: 50%;
        left: -20px;
        transform: translateY(-50%);
      }

      .chip-3 {
        bottom: 100px;
        right: 40px;
      }

      @media (max-width: 768px) {
        .hero {
          padding: 60px 20px;
          min-height: auto;
        }

        .hero-container {
          grid-template-columns: 1fr;
          gap: 60px;
          text-align: left;
        }

        .hero-title {
          font-size: 2.5rem;
        }

        .hero-buttons {
          flex-direction: column;
          align-items: flex-start;
        }

        .hero-btn-primary,
        .hero-btn-secondary {
          width: 100%;
          text-align: center;
          max-width: 280px;
        }

        .hero-stats {
          gap: 24px;
          flex-wrap: wrap;
        }

        .stat-value {
          font-size: 2rem;
        }

        .hero-visual {
          min-height: 500px;
          margin: 0 auto;
          max-width: 400px;
        }

        .hero-bg-gradient {
          width: 380px;
          height: 380px;
        }

        .hero-image {
          width: 320px;
          height: 400px;
        }

        .service-chip {
          font-size: 12px;
          padding: 10px 16px;
        }

        .chip-1 {
          top: 60px;
          right: 10px;
        }

        .chip-2 {
          left: -10px;
        }

        .chip-3 {
          bottom: 80px;
          right: 20px;
        }
      }

      @media (max-width: 480px) {
        .hero-title {
          font-size: 2rem;
        }

        .hero-stats {
          flex-direction: column;
          gap: 20px;
        }

        .stat-label {
          max-width: none;
        }

        .hero-visual {
          min-height: 400px;
        }

        .hero-bg-gradient {
          width: 300px;
          height: 300px;
        }

        .hero-image {
          width: 250px;
          height: 320px;
        }
      }
    </style>

